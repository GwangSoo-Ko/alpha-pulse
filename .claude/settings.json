{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python *)",
      "Bash(python -m pytest *)",
      "Bash(pytest *)",
      "Bash(pip *)",
      "Bash(ap *)",
      "Bash(ruff *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(cd *)",
      "Bash(find *)",
      "Bash(chmod *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous-commands.sh",
            "timeout": 5,
            "statusMessage": "명령어 안전 검사..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ruff-check.sh",
            "timeout": 30,
            "statusMessage": "Ruff 린트 검사 중..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-asyncio-run.sh",
            "timeout": 10,
            "statusMessage": "asyncio.run() 규칙 검사 중..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact-reminder.sh",
            "statusMessage": "핵심 규칙 재주입 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if this session involved code changes (Write/Edit to .py files). If code was changed, verify: 1) Were tests mentioned or run? 2) Were there any unresolved lint errors? If code was changed but tests were NOT run and NOT explicitly skipped by the user, respond with {\"ok\": false, \"reason\": \"Code was modified but tests were not run. Run pytest before completing.\"}. If no code was changed, or tests were run, respond with {\"ok\": true}.",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
